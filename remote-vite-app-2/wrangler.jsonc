{
    "name": "demo-vite-federation-1-remote",
    "main": "worker.ts",
    "compatibility_date": "2024-05-01",
    "assets": {
        "directory": "dist",
        "binding": "ASSETS",
        "run_worker_first": true
    },
    "routes": [
        {
            "pattern": "sub.domain.com/my-path/*",
            "zone_name": "domain.com"
        }
    ]
}